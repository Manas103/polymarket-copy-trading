# Polymarket Copy Trading Bot — Environment Variables
# Copy this file to /opt/copytrade/.env and fill in real values.
#
# IMPORTANT: systemd EnvironmentFile format — no quotes, no export keyword.

# Required: EOA private key (hex, no 0x prefix)
PRIVATE_KEY=your_eoa_private_key_hex_no_0x

# Required: Whale addresses to copy (comma-separated, checksummed)
WHALE_ADDRESSES=0xaddr1,0xaddr2

# Required: Polygon RPC (Alchemy or Infura recommended)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Required: Polymarket CLOB API credentials
CLOB_API_KEY=your_key
CLOB_API_SECRET=your_secret
CLOB_API_PASSPHRASE=your_passphrase

# Optional: Database path (default: copytrade.db in working directory)
DB_PATH=/opt/copytrade/data/copytrade.db

# Optional: Dashboard port (default: 8080)
DASHBOARD_PORT=8080

# Optional: Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
